{
  "name": "mays-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "dev:signal-arena-api": "pnpm --dir workers/signal-arena-api dev",
    "test:signal-arena-worker": "pnpm --dir workers/signal-arena-api test",
    "typecheck:signal-arena-worker": "pnpm --dir workers/signal-arena-api typecheck",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "dev:game-api": "pnpm --dir workers/game-api dev",
    "dev:photo-api": "pnpm --dir workers/photo-api dev",
    "test:ai-daily": "node --test scripts/ai-daily-core.test.mjs",
    "test:ai-daily-visual": "node --test scripts/ai-daily-visual.test.mjs",
    "test:portal": "node --test scripts/portal-layout.test.mjs",
    "test:signal-arena": "node --test scripts/signal-arena-layout.test.mjs",
    "update:ai-daily": "node scripts/update-ai-daily.mjs"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "echarts": "^6.0.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "next": "15.5.15",
    "qrcode": "^1.5.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.5.15",
    "typescript": "^5.9.3",
    "wrangler": "^4.81.1"
  }
}
